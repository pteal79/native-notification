{
    "name": "pteal79/native-notification",
    "description": "A NativePHP plugin for dispatching native notifications via OnNative events",
    "type": "nativephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "PTeal79",
            "email": "info@middevondigital.co.uk"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PTeal79\\NativeNotification\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PTeal79\\NativeNotification\\NativeNotificationServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
